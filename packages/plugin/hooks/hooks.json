{
  "hooks": {
    "SessionStart": [{
      "hooks": [{"type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/clawlens-hook.sh\"", "timeout": 5}]
    }],
    "UserPromptSubmit": [{
      "hooks": [{"type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/clawlens-hook.sh\"", "timeout": 5}]
    }],
    "PreToolUse": [{
      "hooks": [{"type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/clawlens-hook.sh\"", "timeout": 2}]
    }],
    "Stop": [{
      "hooks": [{"type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/clawlens-hook.sh\"", "timeout": 5}]
    }],
    "StopFailure": [{
      "hooks": [{"type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/clawlens-hook.sh\"", "timeout": 2, "async": true}]
    }],
    "SessionEnd": [{
      "hooks": [{"type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/clawlens-hook.sh\"", "timeout": 3, "async": true}]
    }],
    "PostToolUse": [{
      "hooks": [{"type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/clawlens-hook.sh\"", "timeout": 3, "async": true}]
    }],
    "SubagentStart": [{
      "hooks": [{"type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/clawlens-hook.sh\"", "timeout": 2, "async": true}]
    }],
    "PostToolUseFailure": [{
      "hooks": [{"type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/clawlens-hook.sh\"", "timeout": 2, "async": true}]
    }],
    "ConfigChange": [{
      "hooks": [{"type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/clawlens-hook.sh\"", "timeout": 3}]
    }],
    "FileChanged": [{
      "matcher": "settings.json",
      "hooks": [{"type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/clawlens-hook.sh\"", "timeout": 3}]
    }]
  }
}
