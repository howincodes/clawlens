FROM node:22-alpine

# System deps
RUN apk add --no-cache curl bash jq git

# Install Claude Code
RUN npm install -g @anthropic-ai/claude-code

# Install ClawLens client binary
COPY bin/clawlens-linux /usr/local/bin/clawlens
RUN chmod +x /usr/local/bin/clawlens

# Config dir for clawlens
RUN mkdir -p /etc/claude-code/clawlens

# Test workspace
RUN mkdir -p /home/dev/project && \
    cd /home/dev/project && \
    git init && \
    echo "# Test Project" > README.md && \
    git add -A && git config user.email "test@test.com" && git config user.name "Test" && \
    git commit -m "init"

WORKDIR /home/dev/project

COPY scripts/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
