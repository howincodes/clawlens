{
  "name": "clawlens",
  "private": true,
  "version": "0.2.0",
  "description": "AI usage analytics and team management for Claude Code teams",
  "scripts": {
    "dev": "pnpm --filter server dev",
    "build": "pnpm --filter server build && pnpm --filter dashboard build",
    "test": "pnpm --filter server test",
    "lint": "pnpm -r lint",
    "bundle": "pnpm --filter dashboard build && pnpm --filter @clawlens/server bundle"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
