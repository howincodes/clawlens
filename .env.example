# ClawLens Server Configuration

# Required: Admin login password
ADMIN_PASSWORD=change-me

# Server port (default: 3000)
PORT=3000

# SQLite database path (default: ./clawlens.db)
# DB_PATH=/app/data/clawlens.db

# JWT secret for admin session tokens (auto-generated if not set)
# JWT_SECRET=your-random-secret-here

# Comma-separated allowed CORS origins (default: none)
# CORS_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# Path to built dashboard static files (default: auto-detected)
# DASHBOARD_DIR=/app/dashboard/dist

# Public URL of this server (used in install scripts)
# SERVER_URL=https://clawlens.your-domain.com

# Enable verbose debug logging (default: off)
# CLAWLENS_DEBUG=1
